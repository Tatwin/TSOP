rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Daily summaries - readable by authenticated web users, writable only by admin SDK (desktop sync)
    match /dailySummaries/{date} {
      allow read: if request.auth != null;
      allow write: if false; // Only server-side (admin SDK from desktop app)
    }
    
    // Daily entries - readable by authenticated web users
    match /dailyEntries/{date} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    
    // Denominations
    match /denominations/{date} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    
    // Products catalog
    match /products/{productId} {
      allow read: if true; // Public read for product info
      allow write: if false;
    }
    
    // Settings
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
